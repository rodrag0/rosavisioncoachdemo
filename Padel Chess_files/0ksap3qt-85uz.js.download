 q="u">typeof performance,h=q&&["mark","measure","getEntriesByName"].every(e=>"function"==typeof performance[e]);class v extends Error{}class g extends Error{}class f extends Error{constructor(e){super(),this.code="ENOENT",this.name="PageNotFoundError",this.message=`Cannot find module for page: ${e}`}}class y extends Error{constructor(e,o){super(),this.message=`Failed to load static file for page: ${e} ${o}`}}class b extends Error{constructor(){super(),this.code="ENOENT",this.message="Cannot find the middleware module"}}function x(e){return JSON.stringify({message:e.message,stack:e.stack})}},98183,(e,o,a)=>{"use strict";Object.defineProperty(a,"__esModule",{value:!0});var r={assign:function(){return d},searchParamsToUrlQuery:function(){return n},urlQueryToSearchParams:function(){return s}};for(var t in r)Object.defineProperty(a,t,{enumerable:!0,get:r[t]});function n(e){let o={};for(let[a,r]of e.entries()){let e=o[a];void 0===e?o[a]=r:Array.isArray(e)?e.push(r):o[a]=[e,r]}return o}function i(e){return"string"==typeof e?e:("number"!=typeof e||isNaN(e))&&"boolean"!=typeof e?"":String(e)}function s(e){let o=new URLSearchParams;for(let[a,r]of Object.entries(e))if(Array.isArray(r))for(let e of r)o.append(a,i(e));else o.set(a,i(r));return o}function d(e,...o){for(let a of o){for(let o of a.keys())e.delete(o);for(let[o,r]of a.entries())e.append(o,r)}return e}},18566,(e,o,a)=>{o.exports=e.r(76562)},28029,1577,e=>{"use strict";var o=e.i(43476),a=e.i(71645);let r={en:{ui:{welcome:"Welcome to the Padel Chess!",loading:"Loading...",thinkAboutMove:"Think about your next move...",greatJob:"Great job! Let's continue.",confirm:"Confirm",repeat:"Repeat",next:"Next",levelProgress:"Level Progress",level:"Level",toGo:"to go",close:"Close",congratulations:"Congratulations!",youveReached:"You've reached",keepUpGreatWork:"Keep up the great work and continue improving your padel skills!",continue:"Continue",signInTitle:"Sign in",signInDescription:"Unlock the full experience and keep your progress safe.",saveProgress:"Save your progress automatically",syncDevices:"Sync across all your devices",trackJourney:"Track your learning journey",competeFriends:"Compete with friends",openingGoogle:"Opening Google...",continueGoogle:"Continue with Google",maybeLater:"Maybe later",saveProgressBtn:"Save Progress",openScoreboard:"Open Scoreboard",shareQuestion:"Share question",preview:"preview",delivered:"Delivered",yourFriend:"Your friend",seen:"Seen",seenAt:"Seen at",recipientMessage:"Hey, let me see! 😎",shareQuestionBtn:"Share Question",copied:"Copied",play:"Play",savedQuestions:"Saved Questions",noSavedQuestions:"No saved questions yet",dailyLimitReached:"Get Unlimited Puzzles!",dailyLimitSubtitle:"You've hit your daily limit",dailyLimitDescription:"You've solved 5 puzzles today! Come back tomorrow for more or upgrade to unlimited.",subscribeUnlimited:"Subscribe for Unlimited",upgradeToPro:"Upgrade to Padel Chess Premium for unlimited access.",waitForFree:"Wait until tomorrow to continue playing for free.",upgrade:"Upgrade",back:"Back",puzzlePlayersImprove:"Padel Chess players improve",improvementValue:"2.7x Faster",goPremium:"Go Premium",premium:"Premium",mostPopular:"Most Popular",pricePerMonth:"$4.50 / lifetime",featureUnlimitedPuzzles:"Solve unlimited puzzles daily",featureDeepAnalysis:"Deep tactical analysis of every move",featureAdvancedStats:"Advanced statistics and progress tracking",featureCustomTraining:"Custom-made training plans",featureNoAds:"100% Ad-free experience",featurePrioritySupport:"Priority support from our coaches",subscribe:"Subscribe"},content:{q1:"If you want a safe return that won't hit the net, where's the smartest place to aim the ball?",q1_o1:"To the left",q1_o1_exp:"Net height is highest at the edges: 92 cm",q1_o2:"To the center",q1_o2_exp:"Net height is lowest at the center: 88 cm",q1_o3:"To the right",q1_o3_exp:"Net height is highest at the edges: 92 cm",q2:"Where should you aim the ball to keep it safely in the court with the lowest chance of making a mistake?",q2_o1:"Parallel",q2_o1_exp:"The court is only 20 meters long, so there isn't much space for the ball to land inside.",q2_o2:"Crosscourt",q2_o2_exp:"It gives your ball more room to land safely, since the court is ~22 meters along the diagonal.",q3:"Your partner is pushed back to defend. Where should you go?",q3_o1:"Stay at the net",q3_o1_exp:"You'd leave a huge space behind you, and your corner would be wide open.",q3_o2:"Go to the transition zone",q3_o2_exp:"You're stuck in a risky area and your opponents can attack at your feet.",q3_o3:"Go back to defend with your partner",q3_o3_exp:"You both stay safe together and can wait for a better moment to attack again.",q4:"Your partner gets an overhead and will hit a bandeja. Where should you go?",q4_o1:"Stay at the net",q4_o1_exp:"After the bandeja your partner will move forward, so it's better to cover the net together.",q4_o2:"Go to the transition zone",q4_o2_exp:"You'll just have to run forward again and waste energy.",q4_o3:"Go to the defense",q4_o3_exp:"You'd give up the net too easily.",q5:"You're both in defense and your partner receives a drop shot. Where should you go?",q5_o1:"Run to the net with your partner",q5_o1_exp:"Your partner might hit a weak shot, and both of you could get attacked at the net.",q5_o2:"Stay back and defend",q5_o2_exp:"Since the shot might be weak, it's safer to stay in defense and protect the back of the court.",q6:"Where should you stand when serving to make angles better and reach the net faster?",q6_o1:"Close to the side glass",q6_o1_exp:"You'll have to run too far to the net and feel rushed.",q6_o2:"Near the center of your side",q6_o2_exp:"Good angles and not too much running — the best balance.",q6_o3:"In the middle of the court",q6_o3_exp:"You lose good angles and can't serve well toward the opponent's side glass.",q7:"Where is the best place to serve to make the return hard for your opponent?",q7_o1:"Deep serve to the T-zone",q7_o1_exp:"It cuts their attacking angles and may give you an easy volley to the corner.",q7_o2:"Soft serve close to the net (chiquita style)",q7_o2_exp:"They'll just step in and take the net from you.",q7_o3:"Deep to the side glass",q7_o3_exp:"The bounce will be awkward and gives you time to reach the net.",q8:"How should you play your second serve after missing the first one?",q8_o1:"Serve even harder to avoid letting opponents attack",q8_o1_exp:"Too risky — you could double fault.",q8_o2:"Serve safer and just try not to miss",q8_o2_exp:"Better to keep the point going instead of giving it away for free.",q8_o3:"Try a tricky angle to surprise the opponent",q8_o3_exp:"Angles are fun, but risky when you must be consistent.",q9:"Where should you go right after your serve?",q9_o1:"Wait behind the service line to see the opponent's return",q9_o1_exp:"You’ll give up the net.",q9_o2:"Move straight into the attacking zone",q9_o2_exp:"After serving, you should rush to the net to take the advantage.",q10:"Where should you hit your first volley after they return your serve?",q10_o1:"To the opposite corner",q10_o1_exp:"Gives them too many attacking angles.",q10_o2:"To the middle",q10_o2_exp:"A simple and safe shot while you’re still getting balanced at the net.",q10_o3:"Hard back to the same corner",q10_o3_exp:"You might be off-balance from running — too risky.",q11:"Where is it better to return a serve?",q11_o1:"To the server’s partner",q11_o1_exp:"This opponent is well prepared to attack",q11_o2:"Right back at the server",q11_o2_exp:"They’re usually still moving and not ready — great target.",q12:"What’s a good attacking return on a weak second serve?",q12_o1:"Lob and move forward",q12_o1_exp:"Second serves give you more time to play an effective lob and win the net.",q12_o2:"Push a defensive ball crosscourt",q12_o2_exp:"Safe but wastes the chance to attack.",q12_o3:"Chiquita to the server’s feet and move in",q12_o3_exp:"Slower second serves make this really strong for winning the net.",q13:"Where should you send a neutral ball from defense to make a right-handed attacker struggle?",q13_o1:"To their forehand volley",q13_o1_exp:"They can attack too easily.",q13_o2:"To their backhand volley",q13_o2_exp:"Backhand volleys are harder, so they’ll usually play it safe and slow.",q14:"Where should you return from defense to make attackers uncomfortable?",q14_o1:"At their body",q14_o1_exp:"They’ll probably just block it and slow the ball down, giving you time.",q14_o2:"High to their backhand volley",q14_o2_exp:"Hard to hit with control and power.",q14_o3:"To their forehand volley",q14_o3_exp:"Lets them attack a lot more.",q15:"What's the best way to win the net on an easy ball?",q15_o1:"Lob",q15_o1_exp:"The easiest and safest way to take the net.",q15_o2:"Passing shot through the middle",q15_o2_exp:"Can work, but there are better choices if the ball is easy.",q15_o3:"Aim at the backhand volley",q15_o3_exp:"Good for normal balls, but not the best for a really easy one.",q16:"You are defending. You hit two slow balls to the same opponent cross-court. What should you do next?",q16_o1:"Hit a slow ball to the other opponent",q16_o1_exp:"Change the target so the net players don't get too comfortable.",q16_o2:"Hit a faster ball to the same opponent",q16_o2_exp:"Change the speed so the opponent can't easily attack you.",q16_o3:"Hit another slow ball to the same opponent",q16_o3_exp:"If you do the same thing again, they will get used to it and attack you.",dict_bandeja:"Bandeja",dict_bandeja_def:"A special overhead shot where you hit the ball gently with backspin, so it stays low. It helps you keep your spot at the net without trying to win the point immediately.",dict_vibora:"Vibora",dict_vibora_def:"A fast, aggressive overhead shot that looks like a snake bite! You hit the ball with side spin so it stays very low and spins into the corner, making it hard to return.",dict_chiquita:"Chiquita",dict_chiquita_def:"A soft, slow shot aimed at your opponents' feet when they are at the net. It forces them to hit the ball upwards, giving you a chance to attack.",dict_backhand_volley:"Backhand Volley",dict_backhand_volley_def:"Hitting the ball before it bounces, using the back side of your racket. It's like a high-five with the back of your hand!",dict_forehand_volley:"Forehand Volley",dict_forehand_volley_def:"Hitting the ball before it bounces, using the front side of your racket. It's like giving a high-five to the ball!",dict_lob:"Lob",dict_lob_def:"A lob is like a high, soft shot that sails over your opponents' heads and lands deep in their court. It's great for giving yourself time to get back into position or making your opponents run to the back of the court.",dict_drop_shot:"Drop shot",dict_drop_shot_def:"A shot where you hit the ball very close to the net, so it bounces very low. It's great when your opponets are deep and you want to force them to move forward and make a shot on the move, by hitting the low ball very close to the net.",dict_volley:"Volley",dict_volley_def:"Hitting the ball before it bounces, using the front side of your racket. It's like giving a high-five to the ball!"}},ru:{ui:{welcome:"Добро пожаловать в Padel Quiz! Это платформа для освоения навыков падела с помощью тактических викторин, чтобы выигрывать больше игр!",loading:"Загрузка...",thinkAboutMove:"Подумайте о вашем следующем ходе...",greatJob:"Отличная работа! Продолжаем.",confirm:"Подтвердить",repeat:"Повтор",next:"Далее",levelProgress:"Прогресс уровня",level:"Уровень",toGo:"осталось",close:"Закрыть",congratulations:"Поздравляем!",youveReached:"Вы достигли",keepUpGreatWork:"Продолжайте в том же духе и улучшайте свои навыки в паделе!",continue:"Продолжить",signInTitle:"Войти в Padel Chess",signInDescription:"Откройте полный доступ и сохраните свой прогресс.",saveProgress:"Автоматическое сохранение прогресса",syncDevices:"Синхронизация на всех устройствах",trackJourney:"Отслеживайте свой путь обучения",competeFriends:"Соревнуйтесь с друзьями",openingGoogle:"Открываем Google...",continueGoogle:"Продолжить с Google",maybeLater:"Может позже",saveProgressBtn:"Сохранить прогресс",openScoreboard:"Открыть таблицу лидеров",shareQuestion:"Поделиться вопросом",preview:"предпросмотр",delivered:"Доставлено",yourFriend:"Ваш друг",seen:"Прочитано",seenAt:"Прочитано в",recipientMessage:"Привет, сейчас посмотрю! 😎",shareQuestionBtn:"Поделиться вопросом",copied:"Скопировано",play:"Смотреть",savedQuestions:"Сохраненные вопросы",noSavedQuestions:"Нет сохраненных вопросов",dailyLimitReached:"Разблокируйте безлимит!",dailyLimitSubtitle:"Вы достигли дневного лимита",dailyLimitDescription:"Вы решили 5 вопросов сегодня! Приходите завтра или оформите подписку для безлимитного доступа.",subscribeUnlimited:"Подписаться на безлимит",upgradeToPro:"Оформите Padel Chess Pro для безлимитного доступа.",waitForFree:"Подождите до завтра, чтобы продолжить играть бесплатно.",upgrade:"Улучшить",back:"Назад",puzzlePlayersImprove:"Игроки в пазлы прогрессируют",improvementValue:"в 2.7 раза быстрее",goPremium:"Стать Premium",premium:"Premium",mostPopular:"Популярный выбор",pricePerMonth:"599₽/мес",featureUnlimitedPuzzles:"Безлимитные пазлы каждый день",featureDeepAnalysis:"Глубокий тактический анализ ходов",featureAdvancedStats:"Расширенная статистика и трекинг",featureCustomTraining:"Персональные планы тренировок",featureNoAds:"Никакой рекламы",featurePrioritySupport:"Приоритетная поддержка тренеров",subscribe:"Подписаться"},content:{q1:"Если хочешь безопасно вернуть мяч и не попасть в сетку, куда лучше направить удар?",q1_o1:"Влево",q1_o1_exp:"По краям сетка выше: 92 см, сложнее перебить.",q1_o2:"В центр",q1_o2_exp:"По центру сетка ниже всего: 88 см, проще перебить.",q1_o3:"Вправо",q1_o3_exp:"По краям сетка выше: 92 см, сложнее перебить.",q2:"Куда лучше направить мяч, чтобы он с большей вероятностью остался в пределах корта и не ушел в аут?",q2_o1:"Параллельно",q2_o1_exp:"Корт всего 20 метров в длину — мало места для ошибки.",q2_o2:"По диагонали",q2_o2_exp:"Корт по диагонали примерно 22 метра — больше простора для удара.",q3:"Твой партнёр ушёл в защиту, а соперники заняли сетку. Куда тебе идти?",q3_o1:"Остаться у сетки",q3_o1_exp:"Ты оставишь за собой огромную дыру, твой угол будет пустой.",q3_o2:"В переходную зону",q3_o2_exp:"Ты в рискованном месте, соперники легко пробьют тебе под ноги.",q3_o3:"Назад в защиту вместе с партнёром",q3_o3_exp:"Вы будете защищаться вместе и дождётесь шанса вернуться к сетке.",q4:"Партнёр готовится ударить бандеху. Где должен быть ты?",q4_o1:"У сетки",q4_o1_exp:"После бандехи он пойдёт вперёд — лучше держать сетку вдвоём.",q4_o2:"В переходной зоне",q4_o2_exp:"Потом всё равно придётся бежать вперёд — лишняя трата сил.",q4_o3:"В защите",q4_o3_exp:"Слишком легко отдаёшь сетку соперникам.",q5:"Вы оба в защите. Партнёру прилетает дропшот (drop shot). Что делать тебе?",q5_o1:"Бежать к сетке вместе с партнёром",q5_o1_exp:"Партнёр скорее всего вернёт легкий и высокий мяч, который будет легко атакуют соперники.",q5_o2:"Остаться сзади и защищаться",q5_o2_exp:"Твой партнер скорее всего вернёт легкий и высокий мяч, который будет легко атаковать.",q6:"Где встать на подаче, чтобы было удобно подать в боковое стекло соперника и быстрее добежать до сетки?",q6_o1:"Близко к боковому стеклу",q6_o1_exp:"Будешь слишком далеко бежать к сетке — попадёшь под давление.",q6_o2:"Поближе к центру своей стороны",q6_o2_exp:"Хороший угол для подачи в боковое стекло и недалеко бежать — лучший вариант.",q6_o3:"Посередине корта",q6_o3_exp:"Неудобно подавать к боковому стеклу соперника.",q7:"Куда лучше подавать, чтобы сопернику было трудно принять?",q7_o1:"Глубоко в Т-зону",q7_o1_exp:"Меньше углов атаки для соперника, шанс для удобного удара с лёту (volley) для тебя или твоего партнера.",q7_o2:"Мягкая подача ближе к сетке (chiquita)",q7_o2_exp:"Соперники просто подойдут и заберут сетку.",q7_o3:"Глубоко к боковому стеклу",q7_o3_exp:"Мяч отскочит неудобно и даст тебе время занять сетку.",q8:"Как подавать второй раз, если первый не получился?",q8_o1:"Подать ещё сильнее",q8_o1_exp:"Слишком рискованно — можно сделать вторую ошибку и проиграть очко.",q8_o2:"Поспокойнее, с запасом, главное — не промахнуться",q8_o2_exp:"Лучше сохранить розыгрыш, чем подарить очко.",q8_o3:"Подать под хитрым углом",q8_o3_exp:"На второй подаче важно не рисковать слишком сильно.",q9:"Куда двигаться сразу после подачи?",q9_o1:"Остаться за линией подачи",q9_o1_exp:"Так ты отдаёшь сетку соперникам.",q9_o2:"Сразу идти в атаку к сетке",q9_o2_exp:"После подачи нужно быстро занимать сетку.",q10:"Куда лучше сыграть первый удар с лёту (volley) сразу после того, как соперник вернул подачу?",q10_o1:"В противоположный угол",q10_o1_exp:"Слишком много углов для контратаки.",q10_o2:"В середину",q10_o2_exp:"Самый безопасный удар, пока ты ещё ловишь баланс у сетки.",q10_o3:"Сильно в тот же угол",q10_o3_exp:"Ты можешь быть ещё неустойчив — рискованный вариант.",q11:"Куда лучше вернуть подачу?",q11_o1:"Партнёру подающего",q11_o1_exp:"Этот соперник уже готов атаковать.",q11_o2:"Прямо в подающего",q11_o2_exp:"Он ещё движется вперёд и не готов — отличная цель.",q12:"Как лучше вернуть мяч после слабой второй подачи соперника?",q12_o1:"Сделать навесной удар (lob) и идти вперёд",q12_o1_exp:"Будет время занять сетку и начать атаку.",q12_o2:"Мягко отправить по диагонали",q12_o2_exp:"Надёжно, но шанс атаковать пропадает.",q12_o3:"Короткий мягкий удар (chiquita) под ноги подающему и идти вперёд",q12_o3_exp:"Против медленной подачи — супер способ взять сетку.",q13:"Куда отправлять нейтральный мяч из защиты, чтобы правше-атакующему было тяжело?",q13_o1:"Под его удар справа с лёту (forehand volley)",q13_o1_exp:"Он легко пойдёт в атаку.",q13_o2:"Под его удар слева с лёту (backhand volley)",q13_o2_exp:"Удар слева с лёту (backhand volley) сложнее, значит мяч будет медленнее.",q14:"Куда лучше вернуть мяч из защиты, чтобы нападающим было неудобно?",q14_o1:"В корпус соперника",q14_o1_exp:"Соперник просто заблокирует, мяч замедлится, а у тебя будет больше времени.",q14_o2:"Высоко под удар слева с лёту (backhand volley)",q14_o2_exp:"Сложно попасть сильно и точно.",q14_o3:"Под удар справа с лёту (forehand volley)",q14_o3_exp:"Там соперник атакует намного сильнее.",q15:"Как лучше выиграть сетку, если тебе дали легкий мяч?",q15_o1:"Сделать навесной удар (lob) и идти вперёд",q15_o1_exp:"Самый простой и безопасный способ занять сетку.",q15_o2:"Пробить по центру между соперниками",q15_o2_exp:"Иногда сработает, но есть варианты лучше.",q15_o3:"Вернуть мяч под удар слева с лёту (backhand volley) соперника",q15_o3_exp:"Хорошо для обычных мячей, но не лучший выбор для лёгкого.",q16:"Ты в защите. Ты уже дважды сыграл медленно одному и тому же сопернику по диагонали. Что делать дальше?",q16_o1:"Сыграть медленно другому сопернику",q16_o1_exp:"Смени цель, чтобы соперники у сетки не расслаблялись.",q16_o2:"Сыграть быстрее тому же сопернику",q16_o2_exp:"Смени скорость, чтобы сопернику было сложнее подстроиться и атаковать.",q16_o3:"Снова сыграть медленно тому же сопернику",q16_o3_exp:"Если всё время играть одинаково, соперник привыкнет и легко атакует.",dict_bandeja:"Бандеха",dict_bandeja_def:"Удар над головой с нижним вращением, чтобы мяч оставался низким. Помогает сохранить позицию у сетки, не пытаясь выиграть очко сразу.",dict_vibora:"Вибора",dict_vibora_def:"Быстрый, агрессивный удар над головой, похожий на укус змеи. Удар с боковым вращением, чтобы мяч оставался низким и закручивался в угол, усложняя прием.",dict_chiquita:"Чикита",dict_chiquita_def:"Мягкий, медленный удар в ноги соперникам, когда они у сетки. Заставляет их поднимать мяч, давая вам шанс для атаки.",dict_backhand_volley:"Удар слева с лёту",dict_backhand_volley_def:"Удар по мячу до его отскока, тыльной стороной ракетки. Это как дать 'пять' тыльной стороной ладони.",dict_forehand_volley:"Удар справа с лёту",dict_forehand_volley_def:"Удар по мячу до его отскока, лицевой стороной ракетки. Это как дать 'пять' мячу.",dict_lob:"Лоб",dict_lob_def:"Высокий мягкий удар, который летит над головой соперников и приземляется глубоко в их корте. Это отличный способ дать себе время, чтобы занять позицию у сетки.",dict_drop_shot:"Drop shot",dict_drop_shot_def:"Удар по мячу очень близко к сетке, чтобы мяч отскочил очень низко. Это отличный способ заставить соперников двигаться вперед и делать удар в движении по низкому мячу.",dict_volley:"Удар с лёту",dict_volley_def:"Удар по мячу до его отскока, лицевой стороной ракетки. Это как дать 'пять' мячу."}},es:{ui:{welcome:"¡Bienvenido al Quiz de Pádel! Es una plataforma para dominar tus habilidades de pádel con cuestionarios tácticos para ganar más partidos!",loading:"Cargando...",thinkAboutMove:"Piensa en tu próximo movimiento...",greatJob:"¡Buen trabajo! Continuemos.",confirm:"Confirmar",repeat:"Repetir",next:"Siguiente",levelProgress:"Progreso de Nivel",level:"Nivel",toGo:"faltan",close:"Cerrar",congratulations:"¡Felicidades!",youveReached:"Has alcanzado",keepUpGreatWork:"¡Sigue así y continúa mejorando tus habilidades de pádel!",continue:"Continuar",signInTitle:"Sign in",signInDescription:"Unlock the full experience and keep your progress safe.",saveProgress:"Save your progress automatically",syncDevices:"Sync across all your devices",trackJourney:"Track your learning journey",competeFriends:"Compete with friends (coming soon)",openingGoogle:"Opening Google...",continueGoogle:"Continue with Google",maybeLater:"Maybe later",saveProgressBtn:"Save Progress",openScoreboard:"Abrir Tabla de Posiciones",shareQuestion:"Share question",preview:"preview",delivered:"Delivered",yourFriend:"Your friend",seen:"Seen",seenAt:"Seen at",recipientMessage:"Hey, let me see! 😎",shareQuestionBtn:"Share Question",copied:"Copied",play:"Reproducir",savedQuestions:"Preguntas guardadas",noSavedQuestions:"No hay preguntas guardadas aún",dailyLimitReached:"¡Obtén Puzzles Ilimitados!",dailyLimitSubtitle:"Has alcanzado tu límite diario",dailyLimitDescription:"¡Has resuelto 5 preguntas hoy! Vuelve mañana para más o actualiza a ilimitado.",subscribeUnlimited:"Suscríbete para ilimitado",upgradeToPro:"Actualiza a Padel Chess Pro para acceso ilimitado.",waitForFree:"Espera hasta mañana para seguir jugando gratis.",upgrade:"Mejorar",back:"Atrás",puzzlePlayersImprove:"Los jugadores de puzzles mejoran",improvementValue:"2.7x más rápido",goPremium:"Ir a Premium",premium:"Premium",mostPopular:"Más Popular",pricePerMonth:"€9.99/mes",featureUnlimitedPuzzles:"Resuelve puzzles ilimitados diariamente",featureDeepAnalysis:"Análisis táctico profundo de cada movimiento",featureAdvancedStats:"Estadísticas avanzadas y seguimiento",featureCustomTraining:"Planes de entrenamiento personalizados",featureNoAds:"Experiencia 100% sin anuncios",featurePrioritySupport:"Soporte prioritario de nuestros entrenadores",subscribe:"Suscribirse"},content:{q1:"¿Dónde debes devolver la pelota para golpear la red con el menor riesgo?",q1_o1:"A la izquierda",q1_o1_exp:"La altura de la red es máxima en los bordes: 92 cm",q1_o2:"Al centro",q1_o2_exp:"La altura de la red es mínima en el centro: 88 cm",q1_o3:"A la derecha",q1_o3_exp:"La altura de la red es máxima en los bordes: 92 cm",q2:"¿Dónde es mejor golpear la pelota para mantenerla dentro de la pista con el menor riesgo?",q2_o1:"Paralelo",q2_o1_exp:"Hay menos espacio para que la pelota aterrice dentro de la pista, la pista mide 20 metros en línea recta.",q2_o2:"Cruzado",q2_o2_exp:"Le da a tu pelota el máximo espacio para aterrizar dentro de la pista, la pista mide ~22 metros en diagonal.",q3:"Tu compañero se ve obligado a ir a la defensa. ¿Dónde debes ir?",q3_o1:"Quedarte en la red",q3_o1_exp:"Estás creando un gran espacio entre tú y tu compañero, dejando tu esquina abierta.",q3_o2:"Ir a la zona de transición",q3_o2_exp:"Te mantienes vulnerable y permites que tus oponentes jueguen a tus pies.",q3_o3:"Ir a la defensa con tu compañero",q3_o3_exp:"Estás en una buena posición defensiva. Espera la próxima oportunidad para tomar la red.",q4:"Tu compañero recibió un remate y va a jugar una bandeja. ¿Dónde debes ir?",q4_o1:"Quedarte en la red",q4_o1_exp:"Tu compañero va a tomar la red después de la bandeja, así que es mejor cubrir la red con él.",q4_o2:"Ir a la zona de transición",q4_o2_exp:"Tendrás que volver a la red con tu compañero gastando más energía que si te quedas en la red",q4_o3:"Ir a la defensa",q4_o3_exp:"Arriesgas perder la posición en la red yendo a la defensa.",q5:"Ambos están en la defensa y tu compañero recibió un drop shot. ¿Dónde debes ir?",q5_o1:"Llegar a la red con tu compañero para crear presión sobre los oponentes",q5_o1_exp:"Tu compañero probablemente jugará una pelota fácil, por lo que ambos pueden ser atacados en la red.",q5_o2:"Quedarte en la parte trasera de la pista tratando de defender toda la parte trasera",q5_o2_exp:"Tu compañero probablemente jugará una pelota débil que será fácil de atacar, por lo que la defensa es la mejor opción.",q6:"¿Dónde posicionarte para maximizar los ángulos y reducir la distancia a la red al servir?",q6_o1:"Cerca del vidrio lateral de tu lado",q6_o1_exp:"Tendrás que correr una distancia mayor a la red y ponerte bajo presión.",q6_o2:"Cerca del centro de tu lado",q6_o2_exp:"Desde aquí mantienes buenos ángulos de servicio y no necesitas correr demasiado lejos a la red.",q6_o3:"En el medio de la pista",q6_o3_exp:"Desde aquí pierdes ángulos y no puedes servir cómodamente hacia el vidrio.",q7:"¿Qué colocación de servicio es la mejor para hacer que tu oponente luche por devolverlo?",q7_o1:"Servir profundo a la zona T",q7_o1_exp:"Un servicio a la zona T limita los ángulos para tus oponentes y puede abrir una oportunidad de volea al rincón.",q7_o2:"Servicio suave estilo chiquita cerca de la red",q7_o2_exp:"Les da tiempo a tus oponentes para acercarse y tomar la red, perdiendo tu ventaja.",q7_o3:"Servicio profundo al vidrio lateral",q7_o3_exp:"Un servicio profundo al vidrio fuerza al receptor a un rebote incómodo, te da tiempo para llegar a la red.",q8:"¿Cómo debes jugar tu segundo servicio si acabas de fallar el primero?",q8_o1:"Servir aún más fuerte para evitar que los oponentes ataquen",q8_o1_exp:"Aumenta la posibilidad de doble falta y no es lo suficientemente seguro.",q8_o2:"Servir con margen y priorizar no fallar",q8_o2_exp:"En el segundo servicio debes evitar dobles faltas, incluso si el servicio es menos agresivo.",q8_o3:"Intentar un servicio con ángulo complicado para sorprender al oponente",q8_o3_exp:"Los ángulos complicados en un segundo servicio añaden riesgo cuando tu prioridad debería ser la consistencia.",q9:"¿Dónde debes ir justo después de servir?",q9_o1:"Esperar detrás de la línea de servicio para ver el retorno del oponente",q9_o1_exp:"Quedarse atrás después del servicio desequilibra tu equipo y regala la red a tus oponentes.",q9_o2:"Moverse inmediatamente a la zona de ataque",q9_o2_exp:"Después de servir debes moverte rápidamente hacia la red para reclamar la posición de ataque.",q10:"Serviste y te moviste hacia adelante. ¿Dónde debes jugar tu primera volea después de que devuelvan tu servicio de esquina?",q10_o1:"Jugar a la esquina opuesta",q10_o1_exp:"Le das ángulos a tu oponente para atacar.",q10_o2:"Volear al medio",q10_o2_exp:"Justo después de servir debes jugar una primera volea segura, generalmente al medio.",q10_o3:"Atacar la misma esquina agresivamente",q10_o3_exp:"Todavía estás estabilizando tu equilibrio después de correr a la red.",q11:"¿Dónde debes devolver la pelota de un servidor cruzado?",q11_o1:"Devolver al compañero del servidor",q11_o1_exp:"Esto a menudo le da tiempo al servidor para recuperarse y equilibrarse en la red.",q11_o2:"Devolver directamente al servidor",q11_o2_exp:"El servidor generalmente se mueve hacia adelante y está desequilibrado, lo que hace que este retorno sea efectivo.",q12:"¿Cuál es un retorno de ataque efectivo en el segundo servicio de tu oponente?",q12_o1:"Jugar un globo y avanzar",q12_o1_exp:"Los segundos servicios te dan más tiempo para jugar un globo efectivo y ganar la red.",q12_o2:"Empujar una pelota defensiva cruzada",q12_o2_exp:"Esto es seguro pero desperdicia una oportunidad de tomar la red en un segundo servicio débil.",q12_o3:"Jugar una chiquita a los pies del servidor y avanzar",q12_o3_exp:"En un segundo servicio más lento, la chiquita es una forma fuerte de tomar la red.",q13:"¿Dónde devolver una pelota neutral desde posición defensiva para hacer la vida más difícil a los atacantes?",q13_o1:"Lado del derecho del oponente",q13_o1_exp:"Permite a tu oponente atacar más agresivamente.",q13_o2:"Lado del revés del oponente",q13_o2_exp:"Las voleas de revés son complicadas, por lo que los oponentes a menudo juegan seguro, dándote tiempo para reaccionar.",q14:"¿Dónde devolver una pelota neutral desde posición defensiva para hacer la vida más difícil a los atacantes?",q14_o1:"Al cuerpo del oponente",q14_o1_exp:"Los oponentes a menudo solo bloquean la pelota, ralentizándola y dándote más tiempo para el siguiente golpe.",q14_o2:"Volea alta de revés del oponente",q14_o2_exp:"Es difícil golpear con potencia y precisión en este punto.",q14_o3:"Volea de derecho del oponente",q14_o3_exp:"Permite a tu oponente atacar más agresivamente.",q15:"¿Cuál es la mejor forma de ganar la red con una pelota fácil?",q15_o1:"Globo",q15_o1_exp:"Es la forma más fácil de ganar la red.",q15_o2:"Passing shot por el medio",q15_o2_exp:"Puede hacer que ambos oponentes vuelvan a la defensa, pero existen mejores opciones.",q15_o3:"Volea de revés del oponente",q15_o3_exp:"El golpe es bueno para pelotas neutrales, pero para las más fáciles hay mejores opciones."}},pt:{ui:{welcome:"Bem-vindo ao Quiz de Padel! É uma plataforma para dominar suas habilidades de padel com questionários táticos para ganhar mais jogos!",loading:"Carregando...",thinkAboutMove:"Pense no seu próximo movimento...",greatJob:"Ótimo trabalho! Vamos continuar.",confirm:"Confirmar",repeat:"Repetir",next:"Próximo",levelProgress:"Progresso de Nível",level:"Nível",toGo:"faltam",close:"Fechar",congratulations:"Parabéns!",youveReached:"Você alcançou",keepUpGreatWork:"Continue o bom trabalho e continue melhorando suas habilidades de padel!",continue:"Continuar",signInTitle:"Sign in",signInDescription:"Unlock the full experience and keep your progress safe.",saveProgress:"Save your progress automatically",syncDevices:"Sync across all your devices",trackJourney:"Track your learning journey",competeFriends:"Compete with friends (coming soon)",openingGoogle:"Opening Google...",continueGoogle:"Continue with Google",maybeLater:"Maybe later",saveProgressBtn:"Save Progress",openScoreboard:"Abrir Placar",shareQuestion:"Share question",preview:"preview",delivered:"Delivered",yourFriend:"Your friend",seen:"Seen",seenAt:"Seen at",recipientMessage:"Hey, let me see! 😎",shareQuestionBtn:"Share Question",copied:"Copied",play:"Reproduzir",savedQuestions:"Perguntas salvas",noSavedQuestions:"Ainda não há perguntas salvas",dailyLimitReached:"Puzzles Ilimitados!",dailyLimitSubtitle:"Você atingiu seu limite diário",dailyLimitDescription:"Você resolveu 5 perguntas hoje! Volte amanhã para mais ou atualize para ilimitado.",subscribeUnlimited:"Assine para ilimitado",upgradeToPro:"Atualize para o Padel Chess Pro para acesso ilimitado.",waitForFree:"Espere até amanhã para continuar jogando de graça.",upgrade:"Atualizar",back:"Voltar",puzzlePlayersImprove:"Jogadores de puzzles melhoram",improvementValue:"2.7x mais rápido",goPremium:"Mudar para Premium",premium:"Premium",mostPopular:"Mais Popular",pricePerMonth:"R$39,90/mês",featureUnlimitedPuzzles:"Resolva puzzles ilimitados diariamente",featureDeepAnalysis:"Análise tática profunda de cada movimento",featureAdvancedStats:"Estatísticas avançadas e acompanhamento",featureCustomTraining:"Planos de treinamento personalizados",featureNoAds:"Experiência 100% livre de anúncios",featurePrioritySupport:"Suporte prioritário dos nossos treinadores",subscribe:"Assinar"},content:{q1:"Para onde você deve devolver a bola para acertar a rede com o menor risco?",q1_o1:"Para a esquerda",q1_o1_exp:"A altura da rede é máxima nas bordas: 92 cm",q1_o2:"Para o centro",q1_o2_exp:"A altura da rede é mínima no centro: 88 cm",q1_o3:"Para a direita",q1_o3_exp:"A altura da rede é máxima nas bordas: 92 cm",q2:"Onde é melhor acertar a bola para mantê-la dentro da quadra com o menor risco?",q2_o1:"Paralelo",q2_o1_exp:"Há menos espaço para a bola pousar dentro da quadra, a quadra mede 20 metros em linha reta.",q2_o2:"Cruzado",q2_o2_exp:"Dá à sua bola o máximo espaço para pousar dentro da quadra, a quadra mede ~22 metros na diagonal.",q3:"Seu parceiro é forçado a ir para a defesa. Para onde você deve ir?",q3_o1:"Ficar na rede",q3_o1_exp:"Você está criando uma grande lacuna entre você e seu parceiro, deixando seu canto aberto.",q3_o2:"Ir para a zona de transição",q3_o2_exp:"Você está se mantendo vulnerável e permitindo que seus oponentes joguem aos seus pés.",q3_o3:"Ir para a defesa com seu parceiro",q3_o3_exp:"Você está em uma boa posição defensiva. Aguarde a próxima oportunidade de tomar a rede.",q4:"Seu parceiro recebeu um tiro por cima e vai jogar uma bandeja. Para onde você deve ir?",q4_o1:"Ficar na rede",q4_o1_exp:"Seu parceiro vai tomar a rede após a bandeja, então é melhor cobrir a rede com ele.",q4_o2:"Ir para a zona de transição",q4_o2_exp:"Você terá que voltar para a rede com seu parceiro gastando mais energia do que se você ficar na rede",q4_o3:"Ir para a defesa",q4_o3_exp:"Você está arriscando perder a posição na rede indo para a defesa.",q5:"Vocês dois estão na defesa e seu parceiro recebeu um drop shot. Para onde você deve ir?",q5_o1:"Chegar à rede com seu parceiro para criar pressão nos oponentes",q5_o1_exp:"Seu parceiro provavelmente jogará uma bola fácil, então vocês dois podem ser atacados na rede.",q5_o2:"Ficar na parte de trás da quadra tentando defender toda a parte de trás",q5_o2_exp:"Seu parceiro provavelmente jogará uma bola fraca que será fácil de atacar, então a defesa é a melhor opção.",q6:"Onde se posicionar para maximizar os ângulos e reduzir a distância até a rede ao sacar?",q6_o1:"Perto do vidro lateral do seu lado",q6_o1_exp:"Você terá que correr uma distância maior até a rede e se colocar sob pressão.",q6_o2:"Perto do centro do seu lado",q6_o2_exp:"Daqui você mantém bons ângulos de saque e não precisa correr muito longe até a rede.",q6_o3:"No meio da quadra",q6_o3_exp:"Daqui você perde ângulos e não pode sacar confortavelmente em direção ao vidro.",q7:"Qual colocação de saque é a melhor para fazer seu oponente lutar para devolvê-lo?",q7_o1:"Sacar fundo para a zona T",q7_o1_exp:"Um saque para a zona T limita os ângulos para seus oponentes e pode abrir uma oportunidade de voleio no canto.",q7_o2:"Saque suave estilo chiquita perto da rede",q7_o2_exp:"Dá tempo aos seus oponentes para avançar e tomar a rede, fazendo você perder a vantagem.",q7_o3:"Saque fundo para o vidro lateral",q7_o3_exp:"Um saque fundo para o vidro força o receptor a um rebote desconfortável, dando-lhe tempo para chegar à rede.",q8:"Como você deve jogar seu segundo saque se acabou de errar o primeiro?",q8_o1:"Sacar ainda mais forte para evitar que os oponentes ataquem",q8_o1_exp:"Aumenta a chance de dupla falta e não é seguro o suficiente.",q8_o2:"Sacar com margem e priorizar não errar",q8_o2_exp:"No segundo saque você deve evitar duplas faltas, mesmo que o saque seja menos agressivo.",q8_o3:"Tentar um saque com ângulo complicado para surpreender o oponente",q8_o3_exp:"Ângulos complicados em um segundo saque adicionam risco quando sua prioridade deveria ser consistência.",q9:"Para onde você deve ir logo após sacar?",q9_o1:"Esperar atrás da linha de saque para ver o retorno do oponente",q9_o1_exp:"Ficar para trás após o saque desequilibra sua equipe e presenteia seus oponentes com a rede.",q9_o2:"Mover-se imediatamente para a zona de ataque",q9_o2_exp:"Após sacar você deve se mover rapidamente em direção à rede para reivindicar a posição de ataque.",q10:"Você sacou e avançou. Para onde você deve jogar seu primeiro voleio depois que eles devolverem seu saque de canto?",q10_o1:"Jogar para o canto oposto",q10_o1_exp:"Você dá ao seu oponente ângulos para atacar.",q10_o2:"Volear para o meio",q10_o2_exp:"Logo após sacar você deve jogar um primeiro voleio seguro, geralmente para o meio.",q10_o3:"Atacar o mesmo canto agressivamente",q10_o3_exp:"Você ainda está estabilizando seu equilíbrio após correr até a rede.",q11:"Para onde você deve devolver a bola de um sacador cruzado?",q11_o1:"Devolver ao parceiro do sacador",q11_o1_exp:"Isso frequentemente dá ao sacador tempo para se recuperar e se equilibrar na rede.",q11_o2:"Devolver diretamente ao sacador",q11_o2_exp:"O sacador geralmente está se movendo para frente e desequilibrado, tornando este retorno eficaz.",q12:"Qual é um retorno de ataque eficaz no segundo saque do seu oponente?",q12_o1:"Jogar um lob e avançar",q12_o1_exp:"Segundos saques lhe dão mais tempo para jogar um lob eficaz e ganhar a rede.",q12_o2:"Empurrar uma bola defensiva cruzada",q12_o2_exp:"Isso é seguro, mas desperdiça uma oportunidade de tomar a rede em um segundo saque fraco.",q12_o3:"Jogar uma chiquita aos pés do sacador e avançar",q12_o3_exp:"Em um segundo saque mais lento, a chiquita é uma forma forte de tomar a rede.",q13:"Para onde devolver uma bola neutra de posição defensiva para dificultar a vida dos atacantes?",q13_o1:"Lado do forehand do oponente",q13_o1_exp:"Permite que seu oponente ataque mais agressivamente.",q13_o2:"Lado do backhand do oponente",q13_o2_exp:"Voleios de backhand são complicados, então os oponentes costumam jogar seguro, dando-lhe tempo para reagir.",q14:"Para onde devolver uma bola neutra de posição defensiva para dificultar a vida dos atacantes?",q14_o1:"Para o corpo do oponente",q14_o1_exp:"Os oponentes geralmente apenas bloqueiam a bola, diminuindo a velocidade e dando-lhe mais tempo para o próximo golpe.",q14_o2:"Voleio alto de backhand do oponente",q14_o2_exp:"É difícil acertar com potência e precisão neste ponto.",q14_o3:"Voleio de forehand do oponente",q14_o3_exp:"Permite que seu oponente ataque mais agressivamente.",q15:"Qual é a melhor maneira de ganhar a rede em uma bola fácil?",q15_o1:"Lob",q15_o1_exp:"É a maneira mais fácil de ganhar a rede.",q15_o2:"Passing shot pelo meio",q15_o2_exp:"Pode fazer ambos os oponentes voltarem para a defesa, mas existem melhores opções.",q15_o3:"Voleio de backhand do oponente",q15_o3_exp:"O golpe é bom para bolas neutras, mas para as mais fáceis existem melhores opções."}}};e.s(["translations",0,r],1577);let t=(0,a.createContext)(void 0);e.s(["LanguageProvider",0,function({children:e}){let[n,i]=(0,a.useState)("en"),[s,d]=(0,a.useState)(!1);return(0,a.useEffect)(()=>{i((navigator.language.toLowerCase(),"en")),d(!0)},[]),(0,o.jsx)(t.Provider,{value:{language:n,setLanguage:e=>{i(e),localStorage.setItem("padel-quiz-lang",e)},t:e=>r[n]?.ui[e]||r.en.ui[e]||"",tc:e=>{let o=r[n]?.content[e];if(o)return o;let a=r.en.content[e];if(a)return a;let t=e.match(/^q(\d+)_o(\d+)(_exp)?$/);if(t){let e=parseInt(t[1],10),o=parseInt(t[2],10),a="_exp"===t[3];return`[Question ${e}, Option ${o}${a?" explanation":""}]`}return e}},children:e})},"useTranslation",0,function(){let e=(0,a.useContext)(t);if(void 0===e)throw Error("useTranslation must be used within a LanguageProvider");return e}],28029)},20565,e=>{"use strict";var o,a=e.i(4570),r=e.i(71645),t=(0,r.createContext)({get client(){return o},bootstrap:void 0}),n=function(e){return"function"==typeof e},i=function(e,o){return(i=Object.setPrototypeOf||({__proto__:[]})instanceof Array&&function(e,o){e.__proto__=o}||function(e,o){for(var a in o)Object.prototype.hasOwnProperty.call(o,a)&&(e[a]=o[a])})(e,o)};"function"==typeof SuppressedError&&SuppressedError;var s={componentStack:null,exceptionEvent:null,error:null};!function(e){if("function"!=typeof e&&null!==e)throw TypeError("Class extends value "+String(e)+" is not a constructor or null");function o(){this.constructor=a}function a(o){var a=e.call(this,o)||this;return a.state=s